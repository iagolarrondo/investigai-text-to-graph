# Copy to ".env" in this folder (same level as README.md) and paste your real key.
# Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional: override default model (see tool_agent.MODEL)
# GEMINI_MODEL=gemini-2.5-flash
#
# Hosted prompts (planner, judge, synthesis, copilot, intent router) embed ``<graph_llm_summary>`` from
# ``data/raw/graph/graph_llm_summary.md`` at process start — restart Streamlit (or your Python process) after editing that file.
#
# Investigation LLM: "gemini" (GEMINI_API_KEY), "anthropic" / "claude" (ANTHROPIC_API_KEY), or "ollama" / "local".
# INVESTIGATION_LLM=anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6
#
# INVESTIGATION_LLM=ollama
# OLLAMA_HOST=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.1
# OLLAMA_TIMEOUT=600
# Optional: max characters sent to Ollama judge/synthesis (trace truncation; default 28000).
# OLLAMA_MAX_TRACE_CHARS=20000
#
# Optional: cap planner–judge outer loops before synthesis (default = unlimited).
# Ollama: 1 = fastest but often stops while judge wants more tools; 2–4 = deeper runs.
# INVESTIGATION_MAX_PLANNER_PHASES=3
#
# Optional: max tool-request rounds per planner segment (defaults: Ollama 12; Gemini & Anthropic 14 if unset).
# INVESTIGATION_PLANNER_MAX_ROUNDS=20
#
# Optional: when **1** (default), the coverage judge prompt also asks for ``answer`` + graph focus when satisfied,
# so the orchestrator can skip a separate synthesis LLM call. Set to **0** / false / off to use the legacy two-call path.
# INVESTIGATION_MERGE_JUDGE_SYNTHESIS=1
#
# Optional: hard cap on **recorded tool steps** per investigation across planner phases (default **30**).
# Set to **0** to disable the cap.
# INVESTIGATION_MAX_TOOL_STEPS=30
#
# Optional (Anthropic planner): stop a planner phase early after a **non-empty composite** tool result.
# This is a heuristic guardrail to reduce tool-call sprawl on some questions.
# INVESTIGATION_EARLY_STOP_ON_COMPOSITE=1
#
# Optional: allow the LLM to **author** new Python graph tools when preflight says insufficient / inefficient.
# Writes under src/graph_query/generated/ and appends src/graph_query/extension_registry.json (git-tracked).
# INVESTIGATION_EXTENSION_AUTHORING=1
#
# Session memory (Streamlit): optional LLM rewrite for contextual follow-ups when
# deterministic rules do not apply. Set to 0/false/off to disable.
# SESSION_MEMORY_LLM_REWRITE=1
