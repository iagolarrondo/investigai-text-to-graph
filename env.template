# --- Graph backend (NetworkX vs Neo4j) ---
# Empty or "networkx" = in-memory CSV graph. "neo4j" = load from Aura / local Neo4j.
# GRAPH_BACKEND=
# NEO4J_URI=
# NEO4J_URL=
# NEO4J_USER=
# NEO4J_USERNAME=
# NEO4J_PASSWORD=
# NEO4J_DATABASE=
#   Aura: set to your **catalog database name** (often ``neo4j``), not the numeric instance id.
#   Digits-only values are ignored as a mistaken instance id.
# NEO4J_AURA_DEFAULT_DATABASE=
#   Aura only: optional session database when ``NEO4J_DATABASE`` is unset (e.g. ``neo4j``).
#   Leave unset to omit ``database=`` (server home graph). ``none`` / ``0`` / ``false`` / ``off`` = omit.
# NEO4J_READ_MODE=
#   ``native`` — named graph tools; ported tools run as engineer-written Cypher on Aura.
#   ``llm_cypher`` — **tool-free** investigation: the planner is a chat loop where the model emits read-only Cypher JSON
#   (no provider tool/function API). See ``src/llm/cypher_planner.py``.
#   Omit for CSV/NetworkX tool execution only (UI can still pick Neo4j in compare mode).
# NEO4J_DRIVER_MODE=
#   Omit (default): Aura ``*.databases.neo4j.io`` uses direct ``bolt+s://`` (avoids routing failures).
#   ``routing`` — force ``neo4j+s://`` cluster routing. ``direct`` — always rewrite to ``bolt*://``.
#   If diagnose / reads fail with ``Database … not found`` on Aura while ``bolt+s`` is in use, try ``routing``.
# NEO4J_USE_DIRECT_BOLT=1
#   Same as ``NEO4J_DRIVER_MODE=direct``.
# NEO4J_TLS_INSECURE=1
#   PoC only: rewrite ``+s`` → ``+ssc`` (driver skips CA verification). **MITM risk** — fix certifi / macOS certs first.
# NEO4J_USE_CERTIFI_CA_BUNDLE=1
#   Default on: set ``SSL_CERT_FILE`` to certifi before connecting (helps macOS verify Aura). Use ``0`` to disable.

# --- Evals tab (optional judge model override) ---
# EVAL_JUDGE_MODEL=
